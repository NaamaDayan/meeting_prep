{
  "manifest_version": 3,
  "name": "Meeting Prep",
  "version": "1.0.0",
  "description": "Generate structured meeting preparation from Google Calendar events.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Meeting Prep",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["identity", "identity.email", "storage", "alarms"],
  "host_permissions": [
    "https://calendar.google.com/*",
    "https://mail.google.com/*",
    "https://www.googleapis.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://calendar.google.com/*",
        "https://mail.google.com/*"
      ],
      "js": ["calendarIds.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "oauth2": {
    "client_id": "576372766248-35909vomoj44ha8or0rgh2tajmjoqcja.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly",
      "openid",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://calendar.google.com/*", "https://mail.google.com/*"]
    }
  ]
}
