MEETING_PREP_PROTOTYPE_PORT=3851
# Raw OpenAI key (sk-...) for local dev. In Lambda you may set OPENAI_API_KEY to an
# SSM parameter path starting with / (see DEPLOY_AWS.md) instead of the key itself.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: used when LLM provider is Anthropic (Claude) and the UI API key is empty.
ANTHROPIC_API_KEY=

# SerpAPI (Google search enrichment). If unset, enrichment returns empty signals and
# enrichment_skipped_reason (briefing may still run with OpenAI).
SERPAPI_KEY=

# Enrichment cache: default local file server/.enrichment-cache.json (gitignored). On AWS Lambda
# without ENRICHMENT_CACHE_TABLE, default is /tmp/meeting-prep-enrichment-cache.json (writable).
# Optional ENRICHMENT_CACHE_PATH overrides the default path (use absolute path on Lambda).
# For durable cross-invocation cache on Lambda, set ENRICHMENT_CACHE_TABLE (pk = String).
# Optional: ENRICHMENT_CACHE_TTL_SEC (Unix ttl attribute on items when using DynamoDB).
# AWS_REGION is required for Dynamo (Lambda sets it automatically).
# ENRICHMENT_CACHE_PATH=
# ENRICHMENT_CACHE_TABLE=
# ENRICHMENT_CACHE_TTL_SEC=604800
# AWS_REGION=us-east-1

# Local mode only (see DEPLOY_AWS.md for Lambda env vars).
# Do not commit server/.env.
