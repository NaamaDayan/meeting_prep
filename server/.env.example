PORT=3847
APP_ENV=development

# OpenAI
# Raw key or SSM parameter path, e.g. /openai/api_key_meeting_prep
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Search
TAVILY_API_KEY=
SERPAPI_KEY=

# Persistence
PERSISTENCE=file
MEETING_PREP_DEV_FILE=data/preps.json

# AWS production
# Region defaults in code; Lambda also provides AWS_REGION automatically.
# AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=

# CORS
# Comma-separated list of full origin strings, e.g. https://app.example.com,chrome-extension://<id>
# Modes:
# - All local: leave empty; development mode allows localhost and (by default) any chrome-extension:// origin.
# - Remote API + unpacked extension (APP_ENV=production): set to chrome-extension://<unpacked-id> (see extension options page).
# - Remote API + published extension: set to chrome-extension://<store-extension-id> (and add unpacked IDs for testers if needed).
# Staging only: you may include chrome-extension://* to allow any extension origin (avoid in public production).
CORS_ALLOWED_ORIGINS=
# In development, allow any chrome-extension:// origin when CORS_ALLOWED_ORIGINS does not list it (default true).
CORS_ALLOW_CHROME_EXTENSION_IN_DEV=true

# Optional admin route protection
ADMIN_TOKEN=
